APP_NAME="ForgeAI PHP CMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:4006

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mongodb
FORGE_DATABASE_URL=mongodb://127.0.0.1:27017/forgeai
MONGODB_DATABASE=forgeai

FORGE_REDIS_URL=redis://127.0.0.1:6379
REDIS_CLIENT=predis
CACHE_STORE=redis
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

FORGE_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
